# Copy this file to .env.local and fill in your Supabase project values.
# Get them from: Supabase Dashboard > Project Settings > API

# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY SECRET — used by the /api routes to write game state.
# DO NOT prefix with NEXT_PUBLIC and never expose it to the browser.
# Found under: Project Settings > API > Project API keys > service_role.
# Also add this to your Vercel Project Environment Variables (Production).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
